<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora Minería Solo Pro</title>
    <style>
        :root { --btc: #f7931a; --bch: #8dc351; --bg: #0f172a; --card: #1e293b; --text: #f8fafc; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); display: flex; justify-content: center; padding: 20px; }
        .dashboard { width: 100%; max-width: 900px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .card { background: var(--card); padding: 2rem; border-radius: 16px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.3); border-top: 4px solid var(--border-color); }
        .btc { --border-color: var(--btc); } .bch { --border-color: var(--bch); }
        .input-group { margin: 1rem 0; }
        label { display: block; margin-bottom: 0.3rem; opacity: 0.8; font-size: 0.8rem; }
        .row { display: grid; grid-template-columns: 1fr 120px; gap: 10px; }
        input, select { width: 100%; padding: 10px; border-radius: 8px; border: none; background: #334155; color: white; box-sizing: border-box; }
        button { width: 100%; padding: 12px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; background: var(--border-color); color: white; transition: 0.3s; margin-top: 10px; }
        button:hover { filter: brightness(1.2); }
        .res { margin-top: 1.5rem; padding: 1rem; border-radius: 8px; background: rgba(0,0,0,0.2); font-size: 0.9rem; }
        .res table { width: 100%; border-collapse: collapse; }
        .res td { padding: 5px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
    </style>
</head>
<body>

<div class="dashboard">
    <script>
        function renderCard(type) {
            document.write(`
                <div class="card ${type.toLowerCase()}">
                    <h2>${type === 'BTC' ? 'Bitcoin' : 'Bitcoin Cash'}</h2>
                    <div class="input-group">
                        <label>Mineros x Velocidad (TH/s)</label>
                        <div class="row">
                            <input type="number" id="${type}Count" value="1" placeholder="Cant.">
                            <input type="number" id="${type}Speed" placeholder="TH/s por minero">
                        </div>
                    </div>
                    <div class="input-group">
                        <label>Horas minando al día</label>
                        <input type="number" id="${type}Hours" value="24">
                    </div>
                    <div class="input-group">
                        <label>Red: Tipo y Valor</label>
                        <div class="row">
                            <input type="number" id="${type}NetVal" placeholder="Valor">
                            <select id="${type}NetType">
                                <option value="hash">Hashrate (TH/s)</option>
                                <option value="diffT">Dificultad (Tera - T)</option>
                                <option value="diffG">Dificultad (Giga - G)</option>
                            </select>
                        </div>
                    </div>
                    <button onclick="calcular('${type}')">Calcular Probabilidades</button>
                    <div id="res${type}" class="res">Ingresa los datos para calcular</div>
                </div>
            `);
        }
        renderCard('BTC'); renderCard('BCH');
    </script>
</div>

<script>
    function calcular(t) {
        const count = parseFloat(document.getElementById(t + 'Count').value);
        const speed = parseFloat(document.getElementById(t + 'Speed').value);
        const hours = parseFloat(document.getElementById(t + 'Hours').value);
        const netVal = parseFloat(document.getElementById(t + 'NetVal').value);
        const type = document.getElementById(t + 'NetType').value;

        if (!count || !speed || !netVal) return alert("Por favor ingresa valores válidos.");

        // Hashrate total real aplicado (normalizado por horas de conexión)
        const userTH = (count * speed) * (hours / 24);
        const userHashH = userTH * 1e12;

        let netHashRateH;
        // Lógica de conversión a Hashrate (H/s)
        if (type === 'diffT') {
            netHashRateH = (netVal * 1e12 * 4294967296) / 600;
        } else if (type === 'diffG') {
            netHashRateH = (netVal * 1e9 * 4294967296) / 600;
        } else {
            netHashRateH = netVal * 1e12;
        }

        const pPerBlock = userHashH / netHashRateH;
        const periods = { "1 Día": 144, "1 Semana": 1008, "1 Mes": 4320, "1 Año": 52560 };
        
        let html = "<table>";
        for (let p in periods) {
            const prob = (1 - Math.pow((1 - pPerBlock), periods[p])) * 100;
            html += `<tr><td>${p}:</td><td align="right"><strong>${prob.toFixed(8)}%</strong></td></tr>`;
        }
        document.getElementById('res' + t).innerHTML = html + "</table>";
    }
</script>
</body>
</html>
